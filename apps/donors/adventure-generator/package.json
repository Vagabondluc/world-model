{
  "name": "dnd-adventure-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:desktop": "pnpm tauri build",
    "build:android": "pnpm tauri android build",
    "build:ios": "pnpm tauri ios build",
    "setup": "node setup.js",
    "setup:dashboard": "python installer/dashboard.py",
    "backend": "cd python-backend && python main.py",
    "backend:dev": "cd python-backend && venv/Scripts/python main.py",
    "build:backend": "cd python-backend && python build_executable.py",
    "install:all": "npm run setup && npm run build:backend",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node node_modules/@playwright/test/cli.js test --ui",
    "test:e2e:update": "node node_modules/@playwright/test/cli.js test --update-snapshots",
    "mutate": "stryker run",
    "mutate:survivors": "stryker run --mutant-filter survived"
  },
  "dependencies": {
    "@emotion/css": "11.11.2",
    "@google/genai": "^1.14.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.6",
    "@types/js-yaml": "^4.0.9",
    "@xyflow/react": "^12.10.0",
    "dexie": "4.0.8",
    "dompurify": "^3.1.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "marked": "^13.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rehype-react": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-wiki-link": "^2.0.1",
    "unified": "^11.0.5",
    "use-sync-external-store": "^1.5.0",
    "uuid": "^13.0.0",
    "zod": "3.23.8",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.27.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.17"
  }
}
