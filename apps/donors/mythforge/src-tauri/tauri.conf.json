{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MythosForge Desktop",
  "version": "0.1.0",
  "identifier": "com.mythosforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../.next/standalone"
  },
  "app": {
    "windows": [
      {
        "title": "MythosForge",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": { "active": false }
}
