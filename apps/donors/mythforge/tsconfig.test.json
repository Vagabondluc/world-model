{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "vitest.setup.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "docs",
    "examples",
    "e2e"
  ]
}
