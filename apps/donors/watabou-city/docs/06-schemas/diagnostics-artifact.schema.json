{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clean-room/diagnostics-artifact.schema.json",
  "title": "DiagnosticsArtifact",
  "type": "object",
  "required": ["seed", "size", "metrics", "invariants", "scores"],
  "properties": {
    "seed": { "type": "integer", "minimum": 0 },
    "size": { "type": "integer", "minimum": 6, "maximum": 40 },
    "metrics": {
      "type": "object",
      "required": [
        "road_trunk_share",
        "road_secondary_share",
        "road_local_share",
        "road_intersection_density",
        "block_count",
        "block_mean_compactness",
        "parcel_frontage_ratio",
        "parcel_mean_aspect_ratio",
        "building_coverage_ratio",
        "building_frontage_ratio",
        "district_count",
        "district_label_coverage",
        "farm_coverage_ratio",
        "tree_density",
        "global_scaffold_coverage",
        "inner_patch_contiguity",
        "gate_core_reachability",
        "post_assignment_geometry_order",
        "scaffold_driven_placement_ratio",
        "river_topology_valid",
        "river_deterministic_replay",
        "unresolved_road_river_intersections",
        "required_cross_river_connectivity",
        "hydro_aware_placement_order",
        "inner_building_coverage",
        "inner_empty_patch_ratio",
        "render_layer_order_stable",
        "host_cell_binding_coverage",
        "cross_cell_feature_tag_coverage",
        "unresolved_river_wall_intersections",
        "unresolved_road_wall_intersections",
        "unresolved_building_wall_intersections",
        "layer_precedence_drift_flag"
      ],
      "properties": {
        "road_trunk_share": { "type": "number" },
        "road_secondary_share": { "type": "number" },
        "road_local_share": { "type": "number" },
        "road_intersection_density": { "type": "number" },
        "block_count": { "type": "number" },
        "block_mean_compactness": { "type": "number" },
        "parcel_frontage_ratio": { "type": "number" },
        "parcel_mean_aspect_ratio": { "type": "number" },
        "building_coverage_ratio": { "type": "number" },
        "building_frontage_ratio": { "type": "number" },
        "district_count": { "type": "number" },
        "district_label_coverage": { "type": "number" },
        "farm_coverage_ratio": { "type": "number" },
        "tree_density": { "type": "number" },
        "global_scaffold_coverage": { "type": "number" },
        "inner_patch_contiguity": { "type": "number" },
        "gate_core_reachability": { "type": "number" },
        "post_assignment_geometry_order": { "type": "number" },
        "scaffold_driven_placement_ratio": { "type": "number" },
        "river_topology_valid": { "type": "number" },
        "river_deterministic_replay": { "type": "number" },
        "unresolved_road_river_intersections": { "type": "number" },
        "required_cross_river_connectivity": { "type": "number" },
        "hydro_aware_placement_order": { "type": "number" },
        "inner_building_coverage": { "type": "number" },
        "inner_empty_patch_ratio": { "type": "number" },
        "render_layer_order_stable": { "type": "number" },
        "host_cell_binding_coverage": { "type": "number" },
        "cross_cell_feature_tag_coverage": { "type": "number" },
        "unresolved_river_wall_intersections": { "type": "number" },
        "unresolved_road_wall_intersections": { "type": "number" },
        "unresolved_building_wall_intersections": { "type": "number" },
        "layer_precedence_drift_flag": { "type": "number" },
        "globalScaffoldCoverage": { "type": "number" },
        "innerPatchContiguity": { "type": "number" },
        "gateCoreReachability": { "type": "number" },
        "postAssignmentGeometryOrder": { "type": "number" },
        "scaffoldDrivenPlacementRatio": { "type": "number" },
        "riverTopologyValid": { "type": "number" },
        "riverDeterministicReplay": { "type": "number" },
        "unresolvedRoadRiverIntersections": { "type": "number" },
        "requiredCrossRiverConnectivity": { "type": "number" },
        "hydroAwarePlacementOrder": { "type": "number" },
        "innerBuildingCoverage": { "type": "number" },
        "innerEmptyPatchRatio": { "type": "number" },
        "renderLayerOrderStable": { "type": "number" },
        "hostCellBindingCoverage": { "type": "number" },
        "crossCellFeatureTagCoverage": { "type": "number" },
        "unresolvedRiverWallIntersections": { "type": "number" },
        "unresolvedRoadWallIntersections": { "type": "number" },
        "unresolvedBuildingWallIntersections": { "type": "number" },
        "layerPrecedenceDriftFlag": { "type": "number" }
      },
      "additionalProperties": true
    },
    "invariants": {
      "type": "object",
      "properties": {
        "all_pass": { "type": "boolean" },
        "failed": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["all_pass", "failed"],
      "additionalProperties": true
    },
    "scores": {
      "type": "object",
      "properties": {
        "road_readability_score": { "type": "number" },
        "district_semantic_score": { "type": "number" },
        "settlement_legibility_score": { "type": "number" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
