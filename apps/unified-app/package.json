{
  "name": "unified-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:characterize:mythforge": "node scripts/characterize-donor.mjs mythforge && vitest run tests/characterization/mythforge.characterization.test.ts",
    "test:characterize:orbis": "node scripts/characterize-donor.mjs orbis && vitest run tests/characterization/orbis.characterization.test.ts",
    "test:characterize:adventure": "node scripts/characterize-donor.mjs adventure-generator && vitest run tests/characterization/adventure-generator.characterization.test.ts",
    "test:characterize": "npm run test:characterize:mythforge && npm run test:characterize:orbis && npm run test:characterize:adventure",
    "test:conformance:mythforge": "vitest run tests/conformance/mythforge.conformance.test.tsx",
    "test:conformance:orbis": "vitest run tests/conformance/orbis.conformance.test.tsx",
    "test:conformance:adventure": "vitest run tests/conformance/adventure-generator.conformance.test.tsx",
    "test:conformance": "npm run test:conformance:mythforge && npm run test:conformance:orbis && npm run test:conformance:adventure",
    "test:integration:journeys": "vitest run tests/integration/cross-donor-world-flow.integration.test.tsx tests/integration/cross-donor-adventure-flow.integration.test.tsx tests/integration/context-retention.test.tsx",
    "test:integration:lens-switch": "vitest run tests/integration/lens-switch.smoke.test.tsx",
    "test:integration:round-trip": "vitest run tests/integration/shared-concept-round-trip.test.tsx",
    "test:integration": "npm run test:integration:journeys && npm run test:integration:lens-switch",
    "lint": "node scripts/check-donor-imports.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "ajv": "^8.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
