{
  "name": "unified-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:characterize:mythforge": "node scripts/characterize-donor.mjs mythforge && vitest run tests/characterization/mythforge.characterization.test.ts",
    "test:characterize:orbis": "node scripts/characterize-donor.mjs orbis && vitest run tests/characterization/orbis.characterization.test.ts",
    "test:characterize:adventure": "node scripts/characterize-donor.mjs adventure-generator && vitest run tests/characterization/adventure-generator.characterization.test.ts",
    "test:characterize:mappa-imperium": "node scripts/characterize-donor.mjs mappa-imperium && vitest run tests/characterization/mappa-imperium.characterization.test.ts",
    "test:characterize:dawn-of-worlds": "node scripts/characterize-donor.mjs dawn-of-worlds && vitest run tests/characterization/dawn-of-worlds.characterization.test.ts",
    "test:characterize:faction-image": "node scripts/characterize-donor.mjs faction-image && vitest run tests/characterization/faction-image.characterization.test.ts",
    "test:characterize:watabou-city": "node scripts/characterize-donor.mjs watabou-city && vitest run tests/characterization/watabou-city.characterization.test.ts",
    "test:characterize:encounter-balancer": "node scripts/characterize-donor.mjs encounter-balancer && vitest run tests/characterization/encounter-balancer.characterization.test.ts",
    "test:characterize": "npm run test:characterize:mythforge && npm run test:characterize:orbis && npm run test:characterize:adventure && npm run test:characterize:mappa-imperium && npm run test:characterize:dawn-of-worlds && npm run test:characterize:faction-image && npm run test:characterize:watabou-city && npm run test:characterize:encounter-balancer",
    "test:conformance:bridges": "vitest run tests/conformance/bridge-harness.test.ts tests/conformance/mythforge.bridge.test.ts tests/conformance/orbis.bridge.test.ts tests/conformance/adventure-generator.bridge.test.ts tests/conformance/mappa-imperium.bridge.test.ts tests/conformance/dawn-of-worlds.bridge.test.ts tests/conformance/faction-image.bridge.test.ts tests/conformance/watabou-city.bridge.test.ts tests/conformance/encounter-balancer.bridge.test.ts",
    "test:conformance:mounts": "vitest run tests/conformance/donor-subapp-host.mount.test.tsx",
    "test:conformance:exactness": "vitest run tests/conformance tests/integration",
    "test:conformance:phase9b": "npm run test:conformance:bridges && npm run test:conformance:mounts && npm run test:conformance:exactness",
    "test:conformance:mythforge": "vitest run tests/conformance/mythforge.conformance.test.tsx",
    "test:conformance:orbis": "vitest run tests/conformance/orbis.conformance.test.tsx",
    "test:conformance:adventure": "vitest run tests/conformance/adventure-generator.conformance.test.tsx",
    "test:conformance:mappa-imperium": "vitest run tests/conformance/mappa-imperium.conformance.test.tsx",
    "test:conformance:dawn-of-worlds": "vitest run tests/conformance/dawn-of-worlds.conformance.test.tsx",
    "test:conformance:faction-image": "vitest run tests/conformance/faction-image.conformance.test.tsx",
    "test:conformance:watabou-city": "vitest run tests/conformance/watabou-city.conformance.test.tsx",
    "test:conformance:encounter-balancer": "vitest run tests/conformance/encounter-balancer.conformance.test.tsx",
    "test:conformance": "npm run test:conformance:mythforge && npm run test:conformance:orbis && npm run test:conformance:adventure && npm run test:conformance:mappa-imperium && npm run test:conformance:dawn-of-worlds && npm run test:conformance:faction-image && npm run test:conformance:watabou-city && npm run test:conformance:encounter-balancer",
    "test:integration:journeys": "vitest run tests/integration/cross-donor-world-flow.integration.test.tsx tests/integration/cross-donor-adventure-flow.integration.test.tsx tests/integration/context-retention.test.tsx",
    "test:integration:lens-switch": "vitest run tests/integration/lens-switch.smoke.test.tsx",
    "test:integration:round-trip": "vitest run tests/integration/shared-concept-round-trip.test.tsx",
    "test:integration": "npm run test:integration:journeys && npm run test:integration:lens-switch",
    "lint": "node scripts/check-donor-imports.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "ajv": "^8.17.1",
    "d3-delaunay": "^6.0.4",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.1",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
