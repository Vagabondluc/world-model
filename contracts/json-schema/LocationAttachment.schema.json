{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "BiomeType": {
      "oneOf": [
        {
          "enum": [
            "forest",
            "plains",
            "desert",
            "tundra",
            "mountain",
            "swamp",
            "ocean",
            "urban",
            "ruins",
            "cavern",
            "volcanic",
            "farmland",
            "jungle",
            "savanna",
            "mystic"
          ],
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "other": {
              "type": "string"
            }
          },
          "required": [
            "other"
          ],
          "type": "object"
        }
      ]
    },
    "DiscoveryStatus": {
      "enum": [
        "unknown",
        "surveyed",
        "settled",
        "ruined"
      ],
      "type": "string"
    },
    "HexCoordinate": {
      "properties": {
        "q": {
          "format": "int32",
          "type": "integer"
        },
        "r": {
          "format": "int32",
          "type": "integer"
        },
        "s": {
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "q",
        "r",
        "s"
      ],
      "type": "object"
    }
  },
  "properties": {
    "biome_type": {
      "anyOf": [
        {
          "$ref": "#/definitions/BiomeType"
        },
        {
          "type": "null"
        }
      ]
    },
    "coordinate_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "discovery_status": {
      "anyOf": [
        {
          "$ref": "#/definitions/DiscoveryStatus"
        },
        {
          "type": "null"
        }
      ]
    },
    "hex_coordinate": {
      "anyOf": [
        {
          "$ref": "#/definitions/HexCoordinate"
        },
        {
          "type": "null"
        }
      ]
    },
    "hex_or_cell_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "layer_membership": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "map_anchor": {
      "type": "string"
    },
    "spatial_scope": {
      "type": "string"
    }
  },
  "required": [
    "layer_membership",
    "map_anchor",
    "spatial_scope"
  ],
  "title": "LocationAttachment",
  "type": "object"
}