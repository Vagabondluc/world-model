        "string",
        "null"
      ]
    },
    "schema_class": {
      "$ref": "#/definitions/SchemaClass"
    },
    "schema_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "activation_event_id",
    "external_schema_ref",
    "migration_lineage",
    "schema_class",
    "schema_id",
    "version"
