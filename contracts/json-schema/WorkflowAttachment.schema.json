{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "OwnerRef": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "World": {
              "type": "string"
            }
          },
          "required": [
            "World"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "Entity": {
              "type": "string"
            }
          },
          "required": [
            "Entity"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "Asset": {
              "type": "string"
            }
          },
          "required": [
            "Asset"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "Workflow": {
              "type": "string"
            }
          },
          "required": [
            "Workflow"
          ],
          "type": "object"
        }
      ]
    },
    "WorkflowCheckpoint": {
      "properties": {
        "checkpoint_key": {
          "type": "string"
        },
        "reached_at": {
          "type": "string"
        }
      },
      "required": [
        "checkpoint_key",
        "reached_at"
      ],
      "type": "object"
    },
    "WorkflowStatus": {
      "enum": [
        "Idle",
        "Running",
        "Paused",
        "Completed",
        "Failed"
      ],
      "type": "string"
    },
    "WorkflowStepState": {
      "properties": {
        "state": true,
        "step_key": {
          "type": "string"
        }
      },
      "required": [
        "state",
        "step_key"
      ],
      "type": "object"
    }
  },
  "properties": {
    "activity_type": {
      "type": "string"
    },
    "checkpoints": {
      "items": {
        "$ref": "#/definitions/WorkflowCheckpoint"
      },
      "type": "array"
    },
    "output_references": {
      "items": {
        "$ref": "#/definitions/OwnerRef"
      },
      "type": "array"
    },
    "progress_ratio": {
      "format": "float",
      "type": "number"
    },
    "resumable": {
      "type": "boolean"
    },
    "status": {
      "$ref": "#/definitions/WorkflowStatus"
    },
    "step_state": {
      "items": {
        "$ref": "#/definitions/WorkflowStepState"
      },
      "type": "array"
    },
    "workflow_id": {
      "type": "string"
    }
  },
  "required": [
    "activity_type",
    "checkpoints",
    "output_references",
    "progress_ratio",
    "resumable",
    "status",
    "step_state",
    "workflow_id"
  ],
  "title": "WorkflowAttachment",
  "type": "object"
}