{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "FieldDisposition": {
      "enum": [
        "promoted",
        "dropped",
        "split",
        "reference_only"
      ],
      "type": "string"
    },
    "FieldTypeHint": {
      "enum": [
        "string",
        "integer",
        "number",
        "boolean",
        "array",
        "object",
        "enum",
        "reference",
        "unknown"
      ],
      "type": "string"
    },
    "PromotedConceptTarget": {
      "enum": [
        "world_record",
        "entity_record",
        "location_attachment",
        "schema_binding_record",
        "event_envelope",
        "projection_record",
        "relation_record",
        "asset_record",
        "simulation_attachment",
        "simulation_event_payload_contract",
        "simulation_snapshot_contract",
        "domain_profile_contract",
        "workflow_attachment",
        "workflow_step_contract",
        "workflow_checkpoint_contract",
        "generated_output_reference_contract",
        "location_adventure_linkage_contract"
      ],
      "type": "string"
    },
    "PromotedFieldRecord": {
      "properties": {
        "canonical_field": {
          "type": [
            "string",
            "null"
          ]
        },
        "disposition": {
          "$ref": "#/definitions/FieldDisposition"
        },
        "field_name": {
          "type": "string"
        },
        "field_type": {
          "$ref": "#/definitions/FieldTypeHint"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "provenance": {
          "items": {
            "$ref": "#/definitions/SchemaProvenance"
          },
          "type": "array"
        },
        "required": {
          "type": "boolean"
        }
      },
      "required": [
        "disposition",
        "field_name",
        "field_type",
        "provenance",
        "required"
      ],
      "type": "object"
    },
    "PromotionClass": {
      "enum": [
        "core",
        "simulation",
        "workflow",
        "donor_local",
        "reference_only"
      ],
      "type": "string"
    },
    "PromotionOutcome": {
      "enum": [
        "promoted",
        "split"
      ],
      "type": "string"
    },
    "SchemaProvenance": {
      "properties": {
        "alias_history": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "donor": {
          "$ref": "#/definitions/SpecDonor"
        },
        "promotion_class": {
          "$ref": "#/definitions/PromotionClass"
        },
        "source_concept_name": {
          "type": "string"
        },
        "source_file_path": {
          "type": "string"
        }
      },
      "required": [
        "alias_history",
        "donor",
        "promotion_class",
        "source_concept_name",
        "source_file_path"
      ],
      "type": "object"
    },
    "SpecDonor": {
      "enum": [
        "mythforge",
        "orbis",
        "adventure_generator"
      ],
      "type": "string"
    }
  },
  "properties": {
    "adapter_mapping_key": {
      "type": "string"
    },
    "canonical_schema_name": {
      "type": "string"
    },
    "concept_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "donor": {
      "$ref": "#/definitions/SpecDonor"
    },
    "field_records": {
      "items": {
        "$ref": "#/definitions/PromotedFieldRecord"
      },
      "type": "array"
    },
    "normalized_name": {
      "type": "string"
    },
    "outcome": {
      "$ref": "#/definitions/PromotionOutcome"
    },
    "promotion_class": {
      "$ref": "#/definitions/PromotionClass"
    },
    "provenance": {
      "items": {
        "$ref": "#/definitions/SchemaProvenance"
      },
      "type": "array"
    },
    "rust_type_name": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "target": {
      "$ref": "#/definitions/PromotedConceptTarget"
    }
  },
  "required": [
    "adapter_mapping_key",
    "canonical_schema_name",
    "concept_name",
    "description",
    "donor",
    "field_records",
    "normalized_name",
    "outcome",
    "promotion_class",
    "provenance",
    "rust_type_name",
    "schema_id",
    "target"
  ],
  "title": "PromotedSchemaRecord",
  "type": "object"
}