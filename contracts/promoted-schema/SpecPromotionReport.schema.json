        "excerpt": {
          "type": "string"
        },
        "promotion_class": {
          "$ref": "#/definitions/PromotionClass"
        },
        "provenance": {
          "$ref": "#/definitions/SchemaProvenance"
        },
        "relative_path": {
          "type": "string"
        },
        "source_kind": {
          "$ref": "#/definitions/SpecSourceKind"
