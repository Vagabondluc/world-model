    "AliasGroup": {
      "properties": {
        "aliases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "canonical": {
          "type": "string"
        }
      },
      "required": [
        "aliases",
        "canonical"
      ],
      "type": "object"
    },
    "ConceptAliasMap": {
      "properties": {
        "groups": {
          "items": {
            "$ref": "#/definitions/AliasGroup"
          },
          "type": "array"
        }
      },
      "required": [
        "groups"
      ],
      "type": "object"
    },
    "DroppedConceptRecord": {
      "properties": {
        "concept_id": {
          "type": "string"
        },
        "concept_name": {
          "type": "string"
        },
        "donor": {
          "$ref": "#/definitions/SpecDonor"
        },
        "provenance": {
          "$ref": "#/definitions/SchemaProvenance"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "concept_id",
        "concept_name",
        "donor",
        "provenance",
        "reason"
