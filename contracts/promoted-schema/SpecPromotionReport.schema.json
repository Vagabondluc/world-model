        "expected_concept_families": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "included_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source_kind": {
          "$ref": "#/definitions/SpecSourceKind"
        },
        "source_root": {
          "type": "string"
        }
